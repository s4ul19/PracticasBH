Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "1.", " ", "Obtener", " ", "el", " ", "espaciamiento", " ", 
    "logar\[IAcute]tmico", " ", "de", " ", "referencia", " ", 
    RowBox[{"(", 
     RowBox[{"hasta", " ", "0.01"}], ")"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"xRef", " ", "=", " ", 
     RowBox[{"symData", "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", " ", "All", ",", " ", "1"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"logXRef", " ", "=", " ", 
     RowBox[{"Log10", "[", 
      RowBox[{"Select", "[", 
       RowBox[{"xRef", ",", " ", 
        RowBox[{
         RowBox[{"#", " ", "<=", " ", "0.01"}], " ", "&"}]}], "]"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"deltaLog", " ", "=", " ", 
     RowBox[{"Median", "[", 
      RowBox[{"Differences", "[", "logXRef", "]"}], "]"}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Usamos", " ", "Mediana", " ", "para", " ", "mayor", " ", "robustez"}], 
    " ", "*)"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "2.", " ", "Funci\[OAcute]n", " ", "para", " ", "filtrar", " ", "filas", " ",
      "de", " ", "una", " ", "tabla"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"filtrarLog", "[", "tabla_", "]"}], " ", ":=", " ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"lastLog", " ", "=", " ", 
         RowBox[{"-", "Infinity"}]}], "}"}], ",", "\n", "  ", 
       RowBox[{"Select", "[", 
        RowBox[{"tabla", ",", " ", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"Log10", "[", 
               RowBox[{"#", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "]"}], " ", "-", " ", 
              "lastLog"}], " ", ">=", " ", "deltaLog"}], ",", "\n", "    ", 
            RowBox[{
             RowBox[{"lastLog", " ", "=", " ", 
              RowBox[{"Log10", "[", 
               RowBox[{"#", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ";", " ", "True"}], ",",
             " ", "\n", "    ", "False"}], "]"}], " ", "&"}]}], "]"}]}], "\n",
       "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "3.", " ", "Aplicar", " ", "el", " ", "filtro", " ", "a", " ", "todo", " ",
      "tu", " ", "symData"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"symDataFiltrado", " ", "=", " ", 
     RowBox[{"Map", "[", 
      RowBox[{"filtrarLog", ",", " ", "symData"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"n", " ", "=", " ", 
     RowBox[{"Length", "[", "symDataFiltrado", "]"}]}], ";"}]}]}]], "Input",
