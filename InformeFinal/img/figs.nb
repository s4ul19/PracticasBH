Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Obtiene", " ", "y", " ", "ordena", " ", "la", " ", "lista", " ", "en", " ",
     "un", " ", "solo", " ", "paso"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"archivos", " ", "=", " ", 
     RowBox[{"SortBy", "[", 
      RowBox[{
       RowBox[{"FileNames", "[", 
        RowBox[{"\"\<*Sym.csv\>\"", ",", " ", "dir"}], "]"}], ",", " ", "\n", 
       "   ", 
       RowBox[{
        RowBox[{"ToExpression", " ", "@", " ", 
         RowBox[{"First", " ", "@", " ", 
          RowBox[{"StringCases", "[", 
           RowBox[{
            RowBox[{"FileNameTake", "[", "#", "]"}], ",", " ", 
            RowBox[{"DigitCharacter", " ", ".."}]}], "]"}]}]}], " ", "&"}]}], 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Importa", " ", "los", " ", "datos"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"symData", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Import", "[", 
        RowBox[{"#", ",", " ", "\"\<CSV\>\""}], "]"}], " ", "&"}], " ", "/@", 
      " ", "archivos"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.984657274186028*^9, 3.984657291295129*^9}, {
  3.984657366475675*^9, 3.984657367428886*^9}},
